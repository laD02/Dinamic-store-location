generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id @default(cuid())
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model Store {
  id         String           @id @default(cuid())
  shop       String
  storeName  String
  region     String?
  address    String
  city       String
  state      String
  code       String
  phone      String?
  image      String?
  url        String?
  directions String?
  contract   Json?
  visibility String
  time       Json?
  tags       Json?
  lat        Float?
  lng        Float?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @default(now()) @updatedAt
  dailyStats StoreDailyStat[]
  events     StoreEvent[]

  @@index([shop])
}

model Style {
  id              String   @id @default(cuid())
  shop            String
  primaryColor    String
  secondaryColor  String
  primaryFont     String
  secondaryFont   String
  backgroundColor String
  color           String
  iconColor       String
  shadowColor     String
  transparency    Int
  blur            Int
  anchorx         Int
  anchory         Int
  cornerRadius    Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  mapStyle        String?
  markerIcon      String?

  @@index([shop])
}

model GeocodeCache {
  id        String   @id @default(cuid())
  address   String   @unique
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hitCount  Int      @default(0)
}

model OnBoard {
  id         String @id @default(cuid())
  shop       String @unique
  onBoarding Json?
}

model Key {
  id     String  @id @default(cuid())
  shop   String  @unique
  b2bKey String? @unique
}

model ShopConnection {
  id            String   @id @default(cuid())
  sourceShop    String
  targetShop    String
  sourceShopUrl String
  createdAt     DateTime @default(now())

  @@unique([sourceShop, targetShop])
}

model StoreEvent {
  id            String         @id @default(cuid())
  shop          String
  storeId       String?
  sessionId     String?
  eventType     StoreEventType
  searchKeyword String?
  country       String?
  city          String?
  device        String?
  createdAt     DateTime       @default(now())
  store         Store?         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([shop])
  @@index([storeId])
  @@index([eventType])
  @@index([createdAt])
}

model StoreDailyStat {
  id                      String   @id @default(cuid())
  shop                    String
  storeId                 String?
  date                    DateTime
  uniqueSessions          Int
  uniqueViewSessions      Int      @default(0)
  uniqueSearchSessions    Int      @default(0)
  uniqueDirectionSessions Int      @default(0)
  uniqueCallSessions      Int      @default(0)
  uniqueWebsiteSessions   Int      @default(0)
  store                   Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([shop, storeId, date])
  @@index([shop, storeId, date])
}

model StoreSession {
  id        String   @id @default(cuid())
  shop      String
  storeId   String
  sessionId String
  date      DateTime

  @@unique([shop, storeId, sessionId, date])
  @@index([shop, storeId, date])
}

model ReportSetting {
  id                String    @id @default(cuid())
  shop              String    @unique
  dayOfWeek         String    @default("Monday")
  dayOfMonth        Int       @default(1)
  dailyTime         String    @default("09:00")
  weeklyTime        String    @default("09:00")
  monthlyTime       String    @default("09:00")
  inAppDaily        Boolean   @default(false)
  inAppWeekly       Boolean   @default(false)
  inAppMonthly      Boolean   @default(false)
  lastDailySentAt   DateTime?
  lastWeeklySentAt  DateTime?
  lastMonthlySentAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  shop      String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([isRead])
}

model Plan {
  id        String   @id @default(cuid())
  shop      String   @unique
  level     String   @default("basic")
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StoreEventType {
  SEARCH
  VIEW_STORE
  CLICK_DIRECTION
  CLICK_CALL
  CLICK_WEBSITE
}
