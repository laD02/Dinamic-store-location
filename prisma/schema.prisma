generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id @default(cuid())
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model Store {
  id         String   @id @default(cuid())
  shop       String   
  storeName  String
  region     String?
  address    String
  city       String
  state      String
  code       String
  phone      String?
  image      String?
  url        String?
  directions String?
  contract   Json?
  visibility String
  time       Json?
  tags       Json?
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  events     StoreEvent[] 
  dailyStats StoreDailyStat[]
}

model Style {
  id              String   @id @default(cuid())
  shop            String   
  primaryColor    String
  secondaryColor  String
  primaryFont     String
  secondaryFont   String
  backgroundColor String
  color           String
  iconColor       String
  shadowColor     String
  transparency    Int
  blur            Int
  anchorx         Int
  anchory         Int
  cornerRadius    Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
}

model GeocodeCache {
  id        String   @id @default(cuid())
  address   String   @unique // Địa chỉ đã normalize
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hitCount  Int      @default(0) // Số lần cache được dùng
}

model OnBoard {
  id              String @id @default(cuid())
  shop            String @unique
  onBoarding       Json?
}

model Key {
  id      String  @id @default(cuid())
  shop    String  @unique
  b2bKey  String? @unique
}

model ShopConnection {
  id            String   @id @default(cuid())

  sourceShop    String   // shop tạo key
  targetShop    String   // shop nhập key
  sourceShopUrl String   // url của shop tạo
  createdAt     DateTime @default(now())

  @@unique([sourceShop, targetShop])
}

model StoreEvent {
  id        String   @id @default(cuid())

  shop      String   // shopify domain

  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  sessionId String?  // để group 1 user session
  eventType StoreEventType

  searchKeyword String?
  country       String?
  city          String?
  device        String?  // mobile / desktop

  createdAt DateTime @default(now())

  @@index([shop])
  @@index([storeId])
  @@index([eventType])
  @@index([createdAt])
}

model StoreDailyStat {
  id        String   @id @default(cuid())

  shop      String
  storeId   String? 
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  date      DateTime  // lưu dạng 2026-02-27 00:00:00

  searchCount     Int @default(0)
  viewCount       Int @default(0)
  directionCount  Int @default(0)
  callCount       Int @default(0)
  websiteCount    Int @default(0)

  @@unique([shop, storeId, date])
  @@index([shop, date])
}

enum StoreEventType {
  SEARCH
  VIEW_STORE
  CLICK_DIRECTION
  CLICK_CALL
  CLICK_WEBSITE
}

